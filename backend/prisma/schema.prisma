generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  APPROVED
  REJECTED
  ENROLLED
}

enum VerificationStatus {
  UNVERIFIED
  VERIFIED
  REJECTED
}

enum CertificateStatus {
  VALID
  EXPIRED
  REVOKED
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String
  role      UserRole   @default(ADMIN)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("users")
}

model Faculty {
  id               Int          @id @default(autoincrement())
  name             String
  slug             String       @unique
  shortDescription String?      @db.Text
  fullDescription  String?      @db.Text
  image            String?
  isPopular        Boolean      @default(false)
  status           RecordStatus @default(ACTIVE)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  courses      Course[]
  applications Application[]

  @@index([status])
  @@index([isPopular])
  @@map("faculties")
}

model Course {
  id               Int          @id @default(autoincrement())
  facultyId        Int
  name             String
  slug             String       @unique
  shortOverview    String?      @db.Text
  description      String?      @db.Text
  duration         String?
  requirements     String?      @db.Text
  fee              Decimal?     @db.Decimal(10, 2)
  hasCertificate   Boolean      @default(false)
  image            String?
  status           RecordStatus @default(ACTIVE)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  faculty      Faculty       @relation(fields: [facultyId], references: [id], onDelete: Restrict)
  classes      Class[]
  applications Application[]
  certificates Certificate[]

  @@index([facultyId])
  @@index([status])
  @@index([hasCertificate])
  @@map("courses")
}

model Class {
  id             Int          @id @default(autoincrement())
  courseId       Int
  name           String
  startDate      DateTime?
  endDate        DateTime?
  schedule       String?      @db.Text
  availableSeats Int?
  status         RecordStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  course       Course        @relation(fields: [courseId], references: [id], onDelete: Restrict)
  applications Application[]

  @@index([courseId])
  @@index([status])
  @@map("classes")
}

model Application {
  id                     Int                @id @default(autoincrement())
  fullName               String
  email                  String
  phone                  String
  address                String?            @db.Text
  dateOfBirth            DateTime?
  facultyId              Int
  courseId               Int
  classId                Int
  educationQualification String?            @db.Text
  message                String?            @db.Text
  documentPath           String?
  status                 ApplicationStatus  @default(PENDING)
  verificationStatus     VerificationStatus @default(UNVERIFIED)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  faculty      Faculty       @relation(fields: [facultyId], references: [id], onDelete: Restrict)
  course       Course        @relation(fields: [courseId], references: [id], onDelete: Restrict)
  class        Class         @relation(fields: [classId], references: [id], onDelete: Restrict)
  certificates Certificate[]

  @@index([facultyId])
  @@index([courseId])
  @@index([classId])
  @@index([email])
  @@index([status])
  @@index([verificationStatus])
  @@map("applications")
}

model Certificate {
  id                Int               @id @default(autoincrement())
  certificateNumber String            @unique
  applicationId     Int?
  courseId          Int
  studentName       String
  issueDate         DateTime
  expiryDate        DateTime?
  status            CertificateStatus @default(VALID)
  notes             String?           @db.Text
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Restrict)

  @@index([applicationId])
  @@index([courseId])
  @@index([status])
  @@map("certificates")
}

model Testimonial {
  id          Int          @id @default(autoincrement())
  studentName String
  courseName  String
  description String?      @db.Text
  message     String       @db.Text
  photo       String?
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@map("testimonials")
}
